// src/services/api.js
import axios from "axios";

const API_KEY = import.meta.env.VITE_API_KEY;

export const getWeather = async (lat, lon) => {
  const res = await axios.get(
    `https://api.openweathermap.org/data/2.5/weather`,
    {
      params: {
        lat,
        lon,
        appid: API_KEY,
        units: "metric"
      }
    }
  );
  return res.data;
};